{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@ares/utils": [
                "../../packages/utils/src"
            ],
            "@ares/converters": [
                "../../packages/converters/src"
            ]
        },
        "noEmit": true
    },
    "include": [
        "src",
        "vite-env.d.ts"
    ],
    "references": [
        {
            "path": "../../packages/utils"
        },
        {
            "path": "../../packages/converters"
        }
    ]
}